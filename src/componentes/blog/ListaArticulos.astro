---
import TarjetaArticulo from './TarjetaArticulo.astro';
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';
import { formatearFecha } from '../../helpers/sanity';

interface Props { idioma: Idioma; articulos?: any[]; }
const { idioma, articulos = [] } = Astro.props;
const t = obtenerTextos(idioma);
---
<section class="seccion pt-8">
  <div class="contenedor px-4">
    {articulos.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articulos.map((art) => (
          <TarjetaArticulo
            titulo={art.titulo}
            resumen={art.resumen}
            imagen={art.imagen}
            fecha={formatearFecha(art.fecha, idioma)}
            categoria={art.categoria}
            enlace={'/' + idioma + '/blog/' + art.slug}
            textoLeerMas={t.blog.leerMas}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <svg class="w-16 h-16 mx-auto text-slate-300 dark:text-oscuro-borde mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <p class="text-marca-gris dark:text-oscuro-texto text-lg">{t.blog.sinArticulos}</p>
      </div>
    )}
  </div>
</section>
