---
import TarjetaArticulo from './TarjetaArticulo.astro';
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';
interface Props { idioma: Idioma; articulos?: any[]; }
const { idioma, articulos = [] } = Astro.props;
const t = obtenerTextos(idioma);
---
<section class="seccion">
  <div class="contenedor px-4">
    <div class="text-center">
      <h1 class="titulo-seccion">{t.blog.titulo}</h1>
      <p class="subtitulo-seccion mx-auto">{t.blog.subtitulo}</p>
    </div>
    {articulos.length > 0 ? (
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {articulos.map((art) => (
          <TarjetaArticulo titulo={art.titulo} resumen={art.resumen} imagen={art.imagen} fecha={art.fecha} categoria={art.categoria} enlace={'/' + idioma + '/blog/' + (art.slug?.current || art.slug)} textoLeerMas={t.blog.leerMas} />
        ))}
      </div>
    ) : (
      <p class="mt-12 text-center text-marca-gris dark:text-oscuro-texto text-lg">{t.blog.sinArticulos}</p>
    )}
  </div>
</section>
