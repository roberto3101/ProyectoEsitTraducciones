---
interface Props {
  titulo: string;
  resumen: string;
  imagen?: string;
  fecha: string;
  categoria?: string;
  enlace: string;
  textoLeerMas: string;
}
const { titulo, resumen, imagen, fecha, categoria, enlace, textoLeerMas } = Astro.props;
---
<article class="tarjeta overflow-hidden group hover:-translate-y-1 transition-all duration-300">
  <a href={enlace} class="block">
    {imagen ? (
      <img
        src={imagen}
        alt={titulo}
        class="w-full h-52 object-cover rounded-lg mb-4 group-hover:scale-[1.02] transition-transform duration-300"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-52 rounded-lg mb-4 bg-gradient-to-br from-marca-azul to-marca-azulBrillante flex items-center justify-center">
        <svg class="w-12 h-12 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </div>
    )}
  </a>
  <div class="flex items-center gap-3 mb-3">
    {categoria && (
      <span class="text-xs font-semibold uppercase tracking-wider text-marca-azulBrillante bg-marca-azulBrillante/10 px-2.5 py-1 rounded-full">
        {categoria}
      </span>
    )}
    <time class="text-xs text-slate-400 dark:text-slate-500">{fecha}</time>
  </div>
  <h3 class="font-titulo font-semibold text-xl text-marca-azul dark:text-oscuro-titulo group-hover:text-marca-azulBrillante transition-colors leading-tight">
    <a href={enlace}>{titulo}</a>
  </h3>
  <p class="mt-2 text-sm text-marca-gris dark:text-oscuro-texto line-clamp-3 leading-relaxed">{resumen}</p>
  <div class="mt-4 pt-4 border-t border-slate-100 dark:border-oscuro-borde">
    <a href={enlace} class="inline-flex items-center gap-1 text-sm font-semibold text-marca-azulBrillante hover:gap-2 transition-all duration-200">
      {textoLeerMas}
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>
</article>
