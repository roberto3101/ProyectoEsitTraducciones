---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';
import { formatearFecha } from '../../helpers/sanity';
import ContenidoPortable from './ContenidoPortable.astro';

interface Props { idioma: Idioma; articulo: any; }
const { idioma, articulo } = Astro.props;
const t = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);
---
<section class="seccion">
  <div class="contenedor px-4">
    {articulo ? (
      <article class="max-w-3xl mx-auto">
        <!-- Volver al blog -->
        <a
          href={rutas.blog}
          class="inline-flex items-center gap-2 text-sm font-medium text-marca-gris dark:text-oscuro-texto hover:text-marca-azulBrillante transition-colors mb-8"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {t.blog.volver}
        </a>

        <!-- Categoria y fecha -->
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {articulo.categoria && (
            <span class="text-xs font-semibold uppercase tracking-wider text-marca-azulBrillante bg-marca-azulBrillante/10 px-3 py-1 rounded-full">
              {articulo.categoria}
            </span>
          )}
          <time class="text-sm text-slate-400 dark:text-slate-500">
            {t.blog.publicado} {formatearFecha(articulo.fecha, idioma)}
          </time>
        </div>

        <!-- Titulo -->
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-titulo font-bold text-marca-azul dark:text-oscuro-titulo leading-tight">
          {articulo.titulo}
        </h1>

        <!-- Autor -->
        {articulo.autor && (
          <p class="mt-4 text-marca-gris dark:text-oscuro-texto">
            {t.blog.autor} <span class="font-semibold text-marca-azul dark:text-oscuro-titulo">{articulo.autor}</span>
          </p>
        )}

        <!-- Imagen principal -->
        {articulo.imagen && (
          <img
            src={articulo.imagen}
            alt={articulo.titulo}
            class="img-lightbox w-full h-auto rounded-xl mt-8 shadow-lg object-cover max-h-[500px] cursor-zoom-in"
          />
        )}

        <!-- Resumen destacado -->
        {articulo.resumen && (
          <p class="mt-8 text-lg text-marca-gris dark:text-oscuro-texto leading-relaxed border-l-4 border-marca-azulBrillante pl-4 italic">
            {articulo.resumen}
          </p>
        )}

        <!-- Contenido del articulo -->
        <div class="mt-8 contenido-articulo">
          {articulo.contenido && (
            Array.isArray(articulo.contenido)
              ? <ContenidoPortable bloques={articulo.contenido} />
              : <div set:html={articulo.contenido} />
          )}
        </div>

        <!-- Compartir y volver -->
        <div class="mt-12 pt-8 border-t border-slate-200 dark:border-oscuro-borde flex flex-col sm:flex-row items-center justify-between gap-4">
          <a
            href={rutas.blog}
            class="boton-secundario text-sm"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {t.blog.volver}
          </a>
          <div class="flex items-center gap-3">
            <span class="text-sm text-marca-gris dark:text-oscuro-texto">{t.blog.compartir}:</span>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${Astro.url.href}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-slate-100 dark:bg-oscuro-tarjeta flex items-center justify-center text-slate-500 dark:text-oscuro-texto hover:bg-marca-azulBrillante hover:text-white transition-colors"
              aria-label="LinkedIn"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=${Astro.url.href}&text=${encodeURIComponent(articulo.titulo)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-slate-100 dark:bg-oscuro-tarjeta flex items-center justify-center text-slate-500 dark:text-oscuro-texto hover:bg-marca-azulBrillante hover:text-white transition-colors"
              aria-label="Twitter"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
            </a>
            <a
              href={`https://wa.me/?text=${encodeURIComponent(articulo.titulo + ' ' + Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-slate-100 dark:bg-oscuro-tarjeta flex items-center justify-center text-slate-500 dark:text-oscuro-texto hover:bg-green-500 hover:text-white transition-colors"
              aria-label="WhatsApp"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
          </div>
        </div>
      </article>
    ) : (
      <!-- Articulo no encontrado -->
      <div class="text-center py-16 max-w-lg mx-auto">
        <svg class="w-20 h-20 mx-auto text-slate-300 dark:text-oscuro-borde mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 9.75l4.5 4.5m0-4.5l-4.5 4.5M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <h2 class="text-2xl font-titulo font-bold text-marca-azul dark:text-oscuro-titulo">{t.blog.noEncontrado}</h2>
        <p class="mt-3 text-marca-gris dark:text-oscuro-texto">{t.blog.noEncontradoDesc}</p>
        <a href={rutas.blog} class="boton-principal mt-6 inline-flex">
          {t.blog.volver}
        </a>
      </div>
    )}
  </div>
</section>

<!-- Lightbox fullscreen para imagenes -->
<div id="lightbox" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/90 backdrop-blur-sm cursor-zoom-out" role="dialog" aria-modal="true">
  <button id="lightbox-cerrar" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors z-10" aria-label="Cerrar">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <img id="lightbox-img" src="" alt="" class="max-w-[92vw] max-h-[92vh] object-contain rounded-lg shadow-2xl select-none" />
</div>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const cerrarBtn = document.getElementById('lightbox-cerrar');
    if (!lightbox || !lightboxImg) return;

    // Hacer clickeables todas las imagenes del articulo
    const imagenes = document.querySelectorAll('.img-lightbox, .contenido-articulo img');
    imagenes.forEach(img => {
      img.classList.add('cursor-zoom-in');
      img.addEventListener('click', () => {
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt || '';
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    function cerrar() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }

    // Cerrar al click en fondo o boton X
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === cerrarBtn || cerrarBtn.contains(e.target)) cerrar();
    });

    // Cerrar con ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) cerrar();
    });
  });
</script>
