---
import Pregunta from './Pregunta.astro';
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';
interface Props { idioma: Idioma; }
const { idioma } = Astro.props;
const t = obtenerTextos(idioma);
---
<section class="seccion">
  <div class="contenedor px-4">
    <div class="text-center">
      <h1 class="titulo-seccion">{t.preguntas.titulo}</h1>
      <p class="subtitulo-seccion mx-auto">{t.preguntas.subtitulo}</p>
    </div>
    <div class="mt-12 max-w-3xl mx-auto space-y-4">
      {t.preguntas.items.map((item) => (
        <Pregunta pregunta={item.pregunta} respuesta={item.respuesta} />
      ))}
    </div>
  </div>
</section>
