---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';
import { servicios, textosServicios, obtenerRutaServicio, type Servicio } from '../../datos/servicios';

interface Props {
  idioma: Idioma;
  servicio: Servicio;
}

const { idioma, servicio } = Astro.props;
const t = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);
const txt = textosServicios;

// Otros servicios (para la seccion "Otros servicios")
const otrosServicios = servicios.filter((s) => s.id !== servicio.id);
---

<section class="py-16 md:py-24 relative overflow-hidden bg-white dark:bg-oscuro-fondo">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">

    <!-- Volver a servicios -->
    <a
      href={rutas.servicios}
      class="inline-flex items-center gap-2 text-sm font-medium text-marca-gris dark:text-oscuro-texto hover:text-marca-azulBrillante transition-colors mb-10"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      {txt.volver[idioma]}
    </a>

    <!-- Hero del servicio -->
    <div class="relative rounded-2xl overflow-hidden p-8 sm:p-10 lg:p-14 mb-12"
      style={`background: linear-gradient(135deg, ${servicio.color}08, ${servicio.color}15);`}>

      <!-- Linea lateral -->
      <div class="absolute left-0 top-0 bottom-0 w-1.5 rounded-r-full" style={`background: ${servicio.color};`}></div>

      <!-- Decoracion -->
      <div class="absolute -top-20 -right-20 w-64 h-64 rounded-full opacity-[0.07]"
        style={`background: radial-gradient(circle, ${servicio.color}, transparent);`}></div>

      <div class="relative z-10">
        <!-- Icono -->
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 shadow-lg"
          style={`background: ${servicio.color}15; color: ${servicio.color}; --tw-shadow-color: ${servicio.color}15;`}>
          <Fragment set:html={servicio.icono} />
        </div>

        <!-- Titulo -->
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-marca-azul dark:text-white mb-4"
          style="font-family: 'Sora', sans-serif; line-height: 1.15;">
          {servicio.titulo[idioma]}
        </h1>

        <!-- Subtitulo -->
        <p class="text-lg sm:text-xl font-medium mb-6" style={`color: ${servicio.color};`}>
          {servicio.subtitulo[idioma]}
        </p>

        <!-- Descripcion -->
        <p class="text-base sm:text-lg text-marca-gris dark:text-slate-400 leading-relaxed max-w-3xl"
          style="line-height: 1.8;">
          {servicio.descripcion[idioma]}
        </p>
      </div>
    </div>

    <!-- Grid: Especialidades + Sectores -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <!-- Especialidades -->
      <div class="rounded-2xl p-7 sm:p-8 bg-white dark:bg-oscuro-tarjeta border border-slate-100 dark:border-oscuro-borde">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center"
            style={`background: ${servicio.color}10; color: ${servicio.color};`}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5.5 5.5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h2 class="text-lg font-bold text-marca-azul dark:text-white" style="font-family: 'Sora', sans-serif;">
            {txt.especialidades[idioma]}
          </h2>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {servicio.especialidades[idioma].map((esp: string) => (
            <span class="px-4 py-2 text-sm font-semibold rounded-xl transition-colors
              bg-slate-50 text-slate-700 border border-slate-150
              dark:bg-white/[0.05] dark:text-slate-300 dark:border-white/[0.08]"
              style={`border-color: ${servicio.color}20;`}>
              {esp}
            </span>
          ))}
        </div>
      </div>

      <!-- Sectores -->
      <div class="rounded-2xl p-7 sm:p-8 bg-white dark:bg-oscuro-tarjeta border border-slate-100 dark:border-oscuro-borde">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center"
            style={`background: ${servicio.color}10; color: ${servicio.color};`}>
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h2 class="text-lg font-bold text-marca-azul dark:text-white" style="font-family: 'Sora', sans-serif;">
            {txt.sectores[idioma]}
          </h2>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {servicio.sectores[idioma].map((sec: string) => (
            <span class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-xl
              bg-slate-50 text-slate-600 border border-slate-100
              dark:bg-white/[0.04] dark:text-slate-400 dark:border-white/[0.06]">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style={`background: ${servicio.color};`}></span>
              {sec}
            </span>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA principal -->
    <div class="rounded-2xl p-8 sm:p-10 text-center relative overflow-hidden mb-16"
      style={`background: linear-gradient(135deg, ${servicio.color}, ${servicio.color}CC);`}>
      <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-20"
        style="background: radial-gradient(circle, white, transparent);"></div>
      <div class="relative z-10">
        <h3 class="text-2xl sm:text-3xl font-bold text-white mb-3" style="font-family: 'Sora', sans-serif;">
          {txt.ctaTitulo[idioma]}
        </h3>
        <p class="text-white/80 max-w-lg mx-auto mb-7" style="line-height: 1.7;">
          {txt.ctaDesc[idioma]}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href={rutas.contacto}
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-sm font-bold
              bg-white hover:bg-slate-100 shadow-xl shadow-black/10
              transition-all duration-300 hover:-translate-y-0.5"
            style={`color: ${servicio.color}; font-family: 'Sora', sans-serif;`}>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {txt.ctaBoton[idioma]}
          </a>
          <a href="https://wa.me/51998152086" target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl text-sm font-bold
              bg-green-500 hover:bg-green-600 text-white shadow-xl shadow-green-500/20
              transition-all duration-300 hover:-translate-y-0.5"
            style="font-family: 'Sora', sans-serif;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.75.75 0 00.917.918l4.462-1.498A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.296 0-4.429-.67-6.24-1.822l-.436-.29-2.65.89.887-2.637-.318-.462A9.935 9.935 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            {txt.ctaWhatsapp[idioma]}
          </a>
        </div>
      </div>
    </div>

    <!-- Otros servicios -->
    <div>
      <h2 class="text-2xl font-bold text-marca-azul dark:text-white mb-6" style="font-family: 'Sora', sans-serif;">
        {txt.otrosServicios[idioma]}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {otrosServicios.map((otro) => (
          <a href={obtenerRutaServicio(otro, idioma)}
            class="group flex items-center gap-3 p-4 rounded-xl border border-slate-100 dark:border-oscuro-borde
              bg-white dark:bg-oscuro-tarjeta hover:shadow-lg hover:-translate-y-0.5
              transition-all duration-300">
            <div class="w-10 h-10 rounded-lg flex-shrink-0 flex items-center justify-center transition-transform group-hover:scale-110"
              style={`background: ${otro.color}10; color: ${otro.color};`}>
              <Fragment set:html={otro.icono.replace('w-8 h-8', 'w-5 h-5')} />
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-marca-azul dark:text-white truncate">
                {otro.titulo[idioma]}
              </p>
            </div>
            <svg class="w-4 h-4 text-slate-400 dark:text-slate-500 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>
