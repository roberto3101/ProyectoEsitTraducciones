---
import Logo from './Logo.astro';
import SelectorIdioma from './SelectorIdioma.astro';
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';

interface Props {
  idioma: Idioma;
  paginaActual: string;
}

const { idioma, paginaActual } = Astro.props;
const textos = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);

const enlaces = [
  { nombre: textos.nav.inicio, ruta: rutas.inicio, clave: 'inicio' },
  { nombre: textos.nav.nosotros, ruta: rutas.nosotros, clave: 'nosotros' },
  { nombre: textos.nav.servicios, ruta: rutas.servicios, clave: 'servicios' },
  { nombre: textos.nav.blog, ruta: rutas.blog, clave: 'blog' },
  { nombre: textos.nav.contacto, ruta: rutas.contacto, clave: 'contacto' },
];
---

<header class="sticky top-0 z-50 bg-white/95 dark:bg-oscuro-fondo/95 backdrop-blur-md border-b border-slate-100 dark:border-oscuro-borde">
  <nav class="contenedor flex items-center justify-between h-16 md:h-20 px-4">
    <!-- Logo -->
    <Logo />

    <!-- Links de navegacion (desktop) -->
    <ul class="hidden lg:flex items-center gap-6">
      {enlaces.map((enlace) => (
        <li>
          <a
            href={enlace.ruta}
            class:list={[
              'font-cuerpo text-sm font-medium transition-colors duration-200',
              paginaActual === enlace.clave
                ? 'text-marca-azulBrillante border-b-2 border-marca-azulBrillante pb-1'
                : 'text-slate-600 hover:text-marca-azul dark:text-oscuro-texto dark:hover:text-white',
            ]}
          >
            {enlace.nombre}
          </a>
        </li>
      ))}
    </ul>

    <!-- Lado derecho: idiomas + modo oscuro + boton cotizar -->
    <div class="flex items-center gap-3">
      <!-- Selector de idioma (banderas) -->
      <SelectorIdioma idioma={idioma} />

      <!-- Boton modo oscuro -->
      <button
        id="btn-tema"
        class="p-2 rounded-lg text-slate-500 hover:bg-slate-100 dark:text-oscuro-texto dark:hover:bg-oscuro-tarjeta transition-colors"
        aria-label="Cambiar tema"
      >
        <!-- Icono sol (modo claro) -->
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Icono luna (modo oscuro) -->
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <!-- Boton cotizar (desktop) -->
      <a
        href={rutas.contacto}
        class="hidden md:inline-flex boton-principal text-sm"
      >
        {textos.nav.cotizar}
      </a>

      <!-- Boton hamburguesa (movil) -->
      <button
        id="btn-menu"
        class="lg:hidden p-2 rounded-lg text-slate-600 hover:bg-slate-100 dark:text-oscuro-texto dark:hover:bg-oscuro-tarjeta"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menu movil -->
  <div
    id="menu-movil"
    class="hidden lg:hidden bg-white dark:bg-oscuro-fondo border-t border-slate-100 dark:border-oscuro-borde"
  >
    <ul class="py-4 px-4 space-y-2">
      {enlaces.map((enlace) => (
        <li>
          <a
            href={enlace.ruta}
            class:list={[
              'block py-3 px-4 rounded-lg font-cuerpo font-medium transition-colors',
              paginaActual === enlace.clave
                ? 'bg-marca-azulBrillante/10 text-marca-azulBrillante'
                : 'text-slate-600 hover:bg-slate-50 dark:text-oscuro-texto dark:hover:bg-oscuro-tarjeta',
            ]}
          >
            {enlace.nombre}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href={rutas.contacto} class="boton-principal w-full justify-center text-sm">
          {textos.nav.cotizar}
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  // Menu movil: abrir/cerrar
  document.getElementById('btn-menu')?.addEventListener('click', () => {
    document.getElementById('menu-movil')?.classList.toggle('hidden');
  });

  // Modo oscuro: cambiar tema
  document.getElementById('btn-tema')?.addEventListener('click', () => {
    const html = document.documentElement;
    html.classList.toggle('dark');
    localStorage.setItem('tema', html.classList.contains('dark') ? 'oscuro' : 'claro');
  });
</script>
