---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';

interface Props {
  idioma: Idioma;
}

const { idioma } = Astro.props;
const textos = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);
const anio = new Date().getFullYear();
---

<footer class="bg-marca-azul dark:bg-oscuro-tarjeta text-white">
  <div class="contenedor px-4 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Columna 1: Logo y descripcion -->
      <div class="lg:col-span-1">
        <img
          src="/imagenes/logo.png"
          alt="Esit Traducciones"
          class="h-10 w-auto mb-4 brightness-0 invert"
          width="160"
          height="40"
          loading="lazy"
        />
        <p class="text-sm text-slate-300 leading-relaxed">
          {textos.pie.descripcion}
        </p>
      </div>

      <!-- Columna 2: Enlaces -->
      <div>
        <h3 class="font-titulo font-semibold text-lg mb-4">{textos.pie.enlaces}</h3>
        <ul class="space-y-2 text-sm text-slate-300">
          <li><a href={rutas.inicio} class="hover:text-white transition-colors">{textos.nav.inicio}</a></li>
          <li><a href={rutas.nosotros} class="hover:text-white transition-colors">{textos.nav.nosotros}</a></li>
          <li><a href={rutas.servicios} class="hover:text-white transition-colors">{textos.nav.servicios}</a></li>
          <li><a href={rutas.blog} class="hover:text-white transition-colors">{textos.nav.blog}</a></li>
          <li><a href={rutas.contacto} class="hover:text-white transition-colors">{textos.nav.contacto}</a></li>
        </ul>
      </div>

      <!-- Columna 3: Contacto -->
      <div>
        <h3 class="font-titulo font-semibold text-lg mb-4">{textos.pie.contacto}</h3>
        <ul class="space-y-2 text-sm text-slate-300">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <div>
              <p>+51 998 152 086</p>
              <p>+51 998 122 941</p>
              <p>+51 930 872 124</p>
            </div>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <div>
              <p>contacto@esittraducciones.com</p>
              <p>info@esittraducciones.com</p>
            </div>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Pueblo Libre, Lima - Perú</span>
          </li>
        </ul>
      </div>

      <!-- Columna 4: Redes sociales -->
      <div>
        <h3 class="font-titulo font-semibold text-lg mb-4">{textos.pie.legal}</h3>
        <ul class="space-y-2 text-sm text-slate-300 mb-6">
          <li><a href={rutas.privacidad} class="hover:text-white transition-colors">{textos.pie.privacidad}</a></li>
          <li><a href={rutas.terminos} class="hover:text-white transition-colors">{textos.pie.terminos}</a></li>
        </ul>
        <!-- Redes sociales -->
        <div class="flex gap-3">
          <a href="#" aria-label="Facebook" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-white/20 transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Linea divisoria y copyright -->
    <div class="border-t border-white/10 mt-10 pt-6 text-center text-sm text-slate-400">
      <p>&copy; {anio} Esit Traducciones. {textos.pie.derechos}</p>
    </div>
  </div>
</footer>
