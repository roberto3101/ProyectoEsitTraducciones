---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';

interface Props { idioma: Idioma; }

const { idioma } = Astro.props as { idioma: 'es' | 'en' | 'fr' };
const t = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);

const stats: Record<string, { valor: string; label: string }[]> = {
  es: [
    { valor: "33+", label: "Años de experiencia" },
    { valor: "3", label: "Idiomas profesionales" },
    { valor: "500+", label: "Proyectos completados" },
    { valor: "100%", label: "Confidencialidad" },
  ],
  en: [
    { valor: "33+", label: "Years of experience" },
    { valor: "3", label: "Professional languages" },
    { valor: "500+", label: "Projects completed" },
    { valor: "100%", label: "Confidentiality" },
  ],
  fr: [
    { valor: "33+", label: "Ans d'expérience" },
    { valor: "3", label: "Langues professionnelles" },
    { valor: "500+", label: "Projets réalisés" },
    { valor: "100%", label: "Confidentialité" },
  ],
};

const badgeText: Record<string, string> = {
  es: "Agencia de traducción profesional desde 1992",
  en: "Professional translation agency since 1992",
  fr: "Agence de traduction professionnelle depuis 1992",
};
---

<section id="hero-section" class="relative overflow-hidden min-h-[600px] md:min-h-[700px] flex flex-col">

  {/* ============================================================
      IMAGEN DE FONDO
      ============================================================
      Coloca tu imagen en:  public/img/hero/hero-bg.jpg
      Tamaño recomendado:   1920x1080px  o  2560x1440px
      Formato:              .jpg (comprimido ~200-400KB) o .webp
      
      Buenas opciones de foto:
      - Conferencia internacional con intérpretes
      - Mesa de trabajo con documentos en varios idiomas
      - Sala de reuniones profesional
      - Evento diplomático / institucional
      
      Bancos gratuitos sugeridos:
      - unsplash.com (buscar: "conference interpreter", "translation", "international meeting")
      - pexels.com  (buscar: "business conference", "multilingual")
      - pixabay.com
      ============================================================ */}
  
  {/* Hero background image */}
  <div class="absolute inset-0 z-0">
    <img 
      src="/img/hero/hero-bg.jpg"
      alt=""
      class="w-full h-full object-cover hero-img-zoom"
      loading="eager"
      decoding="async"
    />
  </div>

  {/* Dark overlay for text readability — estilo institucional */}
  <div class="absolute inset-0 z-[1]"
    style="background: linear-gradient(
      to right,
      rgba(3, 10, 28, 0.82) 0%,
      rgba(3, 10, 28, 0.7) 35%,
      rgba(3, 10, 28, 0.5) 65%,
      rgba(3, 10, 28, 0.35) 100%
    );">
  </div>

  {/* Subtle bottom gradient to merge with next section */}
  <div class="absolute bottom-0 left-0 right-0 h-32 z-[2] pointer-events-none"
    style="background: linear-gradient(to top, var(--hero-bottom-color, #ffffff) 0%, transparent 100%);">
  </div>
  <div class="absolute bottom-0 left-0 right-0 h-32 z-[2] pointer-events-none hidden dark:block"
    style="background: linear-gradient(to top, #060c18 0%, transparent 100%);">
  </div>

  {/* Decorative accent line — top */}
  <div class="absolute top-0 left-0 right-0 h-1 z-[3] bg-gradient-to-r from-marca-azul via-marca-azulBrillante to-marca-azul/0"></div>

  {/* ============ CONTENT ============ */}
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 relative z-[3] flex-1 flex items-center py-28 md:py-36 lg:py-44">
    <div class="max-w-2xl">

      {/* Badge */}
      <div class="hero-fade-in" style="animation-delay: 0.1s;">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold tracking-wider uppercase
          bg-white/10 text-white/90 border border-white/15 backdrop-blur-sm">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          {badgeText[idioma]}
        </span>
      </div>

      {/* Title — siempre blanco porque va sobre imagen oscura */}
      <h1 class="mt-7 hero-fade-in text-white"
        style="font-family: 'Sora', sans-serif; font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; animation-delay: 0.25s;">
        {t.hero.titulo}
      </h1>

      {/* Subtitle */}
      <p class="mt-6 hero-fade-in text-slate-200/90"
        style="font-size: clamp(1rem, 2vw, 1.2rem); line-height: 1.7; max-width: 540px; animation-delay: 0.4s;">
        {t.hero.subtitulo}
      </p>

      {/* CTAs */}
      <div class="mt-10 flex flex-col sm:flex-row gap-4 hero-fade-in" style="animation-delay: 0.55s;">
        <a href={`/${idioma}/${rutas.contacto}`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg
            bg-marca-azul hover:bg-marca-azulClaro text-white
            font-semibold text-base shadow-xl shadow-black/20 hover:shadow-black/30
            transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0"
          style="font-family: 'Sora', sans-serif;">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {t.hero.botonContacto}
        </a>
        <a href={`/${idioma}/${rutas.servicios}`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg
            border-2 font-semibold text-base transition-all duration-300
            border-white/25 text-white hover:bg-white/10 backdrop-blur-sm"
          style="font-family: 'Sora', sans-serif;">
          {t.hero.botonServicios}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  {/* ============ STATS BAR ============ */}
  <div class="relative z-[3] border-t
    border-white/10 bg-black/30 backdrop-blur-md">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0">
        {stats[idioma].map((s, i) => (
          <div class:list={[
            "py-6 md:py-7 text-center hero-fade-in",
            i < 3 ? "border-r border-white/10" : "",
            i < 2 ? "max-md:border-b max-md:border-white/10" : "",
            i === 2 ? "max-md:border-b max-md:border-white/10 max-md:border-r-0" : "",
            i === 1 ? "max-md:border-r-0" : "",
            i === 3 ? "max-md:border-r-0" : "",
          ]} style={`animation-delay: ${0.6 + i * 0.1}s;`}>
            <div class="text-2xl md:text-3xl font-bold text-white"
              style="font-family: 'Sora', sans-serif;">
              {s.valor}
            </div>
            <div class="mt-1 text-xs md:text-sm text-slate-300/70">
              {s.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-fade-in {
    opacity: 0;
    animation: heroFadeIn 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  /* Sutil Ken Burns — la imagen hace un zoom lento, da sensación cinematográfica */
  @keyframes heroZoom {
    0% { transform: scale(1); }
    100% { transform: scale(1.06); }
  }
  .hero-img-zoom {
    animation: heroZoom 20s ease-in-out infinite alternate;
  }

  /* Fallback: si la imagen no carga, muestra un gradiente institucional azul oscuro */
  #hero-section {
    --hero-bottom-color: #ffffff;
    background: linear-gradient(135deg, #0a1628 0%, #122244 40%, #1a3060 70%, #0a1628 100%);
  }
  :global(.dark) #hero-section {
    --hero-bottom-color: #060c18;
  }
</style>