---
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';

interface Props { idioma: Idioma; }

const { idioma } = Astro.props;
const t = obtenerTextos(idioma);
---

<section class="seccion bg-marca-grisSuave dark:bg-oscuro-tarjeta">
  <div class="contenedor px-4">
    <div class="text-center">
      <h2 class="titulo-seccion">{t.porQueElegirnos.titulo}</h2>
      <p class="subtitulo-seccion mx-auto">{t.porQueElegirnos.subtitulo}</p>
    </div>

    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {t.porQueElegirnos.items.map((item) => (
        <div class="text-center">
          <div class="text-4xl md:text-5xl font-titulo font-bold text-marca-azulBrillante">
            {item.titulo}
          </div>
          <p class="mt-3 text-sm text-marca-gris dark:text-oscuro-texto">
            {item.descripcion}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
