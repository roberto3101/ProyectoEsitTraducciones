---
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';
interface Props { idioma: Idioma; }
const { idioma } = Astro.props;
const t = obtenerTextos(idioma);
---
<section class="seccion bg-marca-grisSuave dark:bg-oscuro-tarjeta">
  <div class="contenedor px-4 max-w-4xl mx-auto">
    <h2 class="titulo-seccion">{t.nosotrosPage.tituloMision}</h2>
    <blockquote class="mt-8 text-xl md:text-2xl text-marca-azulClaro dark:text-marca-azulBrillante font-titulo leading-relaxed italic border-l-4 border-marca-azulBrillante pl-6">{t.nosotrosPage.mision}</blockquote>
  </div>
</section>
