---
import Principal from '../../../layout/Principal.astro';
import DetalleServicio from '../../../componentes/servicios/DetalleServicio.astro';
import { obtenerTextos } from '../../../helpers/idiomas';
import { obtenerSlugsServicios, obtenerServicioPorSlug } from '../../../datos/servicios';

export function getStaticPaths() {
  return obtenerSlugsServicios('en');
}

const { slug } = Astro.params;
const t = obtenerTextos('en');
const servicio = obtenerServicioPorSlug(slug!, 'en');
const titulo = servicio ? `${servicio.titulo.en} | ESIT Translations` : t.seo.servicios.titulo;
const descripcion = servicio ? servicio.descripcion.en.slice(0, 160) : t.seo.servicios.descripcion;
---
<Principal titulo={titulo} descripcion={descripcion} idioma="en" pagina="servicios">
  {servicio && <DetalleServicio idioma="en" servicio={servicio} />}
</Principal>
