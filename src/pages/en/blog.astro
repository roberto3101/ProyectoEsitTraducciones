import { obtenerTextos } from '../../helpers/idiomas';
const t = obtenerTextos('en');
const articulos = [];
---
<Principal titulo={t.seo.blog.titulo} descripcion={t.seo.blog.descripcion} idioma="en" pagina="blog">
