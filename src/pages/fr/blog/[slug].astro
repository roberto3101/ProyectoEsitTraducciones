---
import Principal from '../../../layout/Principal.astro';
import DetalleArticulo from '../../../componentes/blog/DetalleArticulo.astro';
import { obtenerTextos } from '../../../helpers/idiomas';
import { obtenerTodosSlugs, obtenerArticuloPorSlug } from '../../../helpers/sanity';

export async function getStaticPaths() {
  let slugs = [];
  try {
    slugs = await obtenerTodosSlugs('fr');
  } catch (e) {
    console.error('Erreur lors de la récupération des slugs:', e);
  }
  return slugs.map((item: any) => ({ params: { slug: item.slug } }));
}

const { slug } = Astro.params;
const t = obtenerTextos('fr');

let articulo = null;
try {
  articulo = await obtenerArticuloPorSlug(slug!, 'fr');
} catch (e) {
  console.error('Erreur lors de la récupération de l\'article:', e);
}

const titulo = articulo?.titulo || t.blog.noEncontrado;
const descripcion = articulo?.resumen || t.blog.noEncontradoDesc;
---
<Principal titulo={titulo + ' | ESIT Blog'} descripcion={descripcion} idioma="fr" pagina="blog" imagenOG={articulo?.imagen}>
  <DetalleArticulo idioma="fr" articulo={articulo} />
</Principal>
