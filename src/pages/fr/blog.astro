---
import Principal from '../../layout/Principal.astro';
import ListaArticulos from '../../componentes/blog/ListaArticulos.astro';
import FiltroCategoria from '../../componentes/blog/FiltroCategoria.astro';
import { obtenerTextos } from '../../helpers/idiomas';
import { obtenerArticulos, obtenerCategorias } from '../../helpers/sanity';

const t = obtenerTextos('fr');
const categoriaActual = Astro.url.searchParams.get('cat') || '';

let articulos = [];
let categorias: string[] = [];

try {
  [articulos, categorias] = await Promise.all([
    obtenerArticulos('fr'),
    obtenerCategorias('fr'),
  ]);
} catch (e) {
  console.error('Erreur lors de la récupération des articles:', e);
}

const articulosFiltrados = categoriaActual
  ? articulos.filter((a: any) => a.categoria === categoriaActual)
  : articulos;
---
<Principal titulo={t.seo.blog.titulo} descripcion={t.seo.blog.descripcion} idioma="fr" pagina="blog">
  <section class="seccion pb-0">
    <div class="contenedor px-4">
      <div class="text-center">
        <h1 class="titulo-seccion">{t.blog.titulo}</h1>
        <p class="subtitulo-seccion mx-auto">{t.blog.subtitulo}</p>
      </div>
      <FiltroCategoria idioma="fr" categorias={categorias} categoriaActual={categoriaActual} />
    </div>
  </section>
  <ListaArticulos idioma="fr" articulos={articulosFiltrados} />
</Principal>
