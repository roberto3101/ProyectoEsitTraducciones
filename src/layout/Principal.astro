---
import EtiquetasPagina from '../componentes/seo/EtiquetasPagina.astro';
import EnlacesIdiomas from '../componentes/seo/EnlacesIdiomas.astro';
import DatosEmpresa from '../componentes/seo/DatosEmpresa.astro';
import VistaRedesSociales from '../componentes/seo/VistaRedesSociales.astro';
import BarraNavegacion from '../componentes/navegacion/BarraNavegacion.astro';
import PieDePagina from '../componentes/navegacion/PieDePagina.astro';
import BotonWhatsapp from '../componentes/BotonWhatsapp.astro';
import type { Idioma } from '../helpers/idiomas';
import '../estilos/global.css';

interface Props {
  titulo: string;
  descripcion: string;
  idioma: Idioma;
  pagina: string; // nombre de la pagina actual (inicio, nosotros, etc)
  imagenOG?: string;
}

const { titulo, descripcion, idioma, pagina, imagenOG } = Astro.props;
const rutaActual = Astro.url.pathname;

// Google Analytics 4 - Lee el ID desde .env (PUBLIC_GA_MEASUREMENT_ID)
const GA_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-XXXXXXXXXX';
---

<!doctype html>
<html lang={idioma} class="scroll-smooth">
  <head>
    <!-- SEO: Etiquetas basicas -->
    <EtiquetasPagina
      titulo={titulo}
      descripcion={descripcion}
      idioma={idioma}
    />

    <!-- SEO: Decirle a Google que esta pagina existe en 3 idiomas -->
    <EnlacesIdiomas
      idiomaActual={idioma}
      rutaActual={rutaActual}
    />

    <!-- SEO: Vista previa en redes sociales -->
    <VistaRedesSociales
      titulo={titulo}
      descripcion={descripcion}
      idioma={idioma}
      imagen={imagenOG}
    />

    <!-- Google Analytics 4: Monitoreo de visitas y eventos -->
    <script is:inline define:vars={{ GA_ID }}>
      // Solo activar en produccion (no en localhost)
      if (window.location.hostname !== 'localhost' && GA_ID !== 'G-XXXXXXXXXX') {
        // 1. Cargar script de gtag
        const script = document.createElement('script');
        script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
        script.async = true;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', GA_ID);

        // 2. Tracking de eventos cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', function() {

          // --- Clic en cualquier enlace de WhatsApp (boton flotante, servicios, contacto, blog) ---
          document.querySelectorAll('a[href*="wa.me"]').forEach(function(link) {
            link.addEventListener('click', function() {
              // Identificar desde donde hizo clic
              var ubicacion = 'otro';
              if (link.classList.contains('fixed')) ubicacion = 'boton_flotante';
              else if (link.closest('.hero, section')) ubicacion = link.closest('section')?.id || 'seccion';
              else if (link.closest('footer')) ubicacion = 'footer';
              gtag('event', 'clic_whatsapp', {
                event_category: 'contacto',
                event_label: ubicacion
              });
            });
          });

          // --- Clic en enlaces de teléfono ---
          document.querySelectorAll('a[href^="tel:"]').forEach(function(link) {
            link.addEventListener('click', function() {
              gtag('event', 'clic_telefono', {
                event_category: 'contacto',
                event_label: link.getAttribute('href')
              });
            });
          });

          // --- Clic en enlaces de email ---
          document.querySelectorAll('a[href^="mailto:"]').forEach(function(link) {
            link.addEventListener('click', function() {
              gtag('event', 'clic_email', {
                event_category: 'contacto',
                event_label: link.getAttribute('href')
              });
            });
          });

          // --- Clic en botones CTA (Solicitar Cotización, etc.) ---
          document.querySelectorAll('a[href*="contacto"], a[href*="contact"]').forEach(function(link) {
            // Solo los que parecen botones CTA (no links del nav/footer)
            if (link.classList.contains('boton-principal') ||
                link.classList.contains('boton-secundario') ||
                link.closest('.hero, section') && !link.closest('nav, footer')) {
              link.addEventListener('click', function() {
                gtag('event', 'clic_cta', {
                  event_category: 'conversion',
                  event_label: link.textContent.trim().substring(0, 50)
                });
              });
            }
          });

          // --- Envío de formulario de contacto ---
          var formulario = document.getElementById('formulario-contacto');
          if (formulario) {
            formulario.addEventListener('submit', function() {
              var servicio = formulario.querySelector('#servicio');
              var origen = formulario.querySelector('#campo-origen');
              gtag('event', 'envio_formulario', {
                event_category: 'conversion',
                event_label: servicio ? servicio.value : 'no_especificado',
                origen_visitante: origen ? origen.value : 'desconocido'
              });
            });
          }

          // --- Clic en redes sociales ---
          document.querySelectorAll('a[aria-label="Facebook"], a[aria-label="Instagram"], a[aria-label="LinkedIn"]').forEach(function(link) {
            link.addEventListener('click', function() {
              gtag('event', 'clic_red_social', {
                event_category: 'redes_sociales',
                event_label: link.getAttribute('aria-label')
              });
            });
          });

          // --- Cambio de idioma (banderas en el navbar) ---
          document.querySelectorAll('a[aria-label^="Cambiar idioma"]').forEach(function(link) {
            link.addEventListener('click', function() {
              // Extraer el idioma del aria-label: "Cambiar idioma a Español" -> "Español"
              var idioma = (link.getAttribute('aria-label') || '').replace('Cambiar idioma a ', '');
              gtag('event', 'cambio_idioma', {
                event_category: 'navegacion',
                event_label: idioma
              });
            });
          });

          // --- Scroll depth tracking (25%, 50%, 75%, 100%) ---
          var scrollMarcas = { 25: false, 50: false, 75: false, 100: false };
          window.addEventListener('scroll', function() {
            var alturaDoc = document.documentElement.scrollHeight - window.innerHeight;
            if (alturaDoc <= 0) return;
            var porcentaje = Math.round((window.scrollY / alturaDoc) * 100);
            [25, 50, 75, 100].forEach(function(marca) {
              if (porcentaje >= marca && !scrollMarcas[marca]) {
                scrollMarcas[marca] = true;
                gtag('event', 'scroll_profundidad', {
                  event_category: 'engagement',
                  event_label: marca + '%'
                });
              }
            });
          });

        }); // fin DOMContentLoaded
      } // fin check produccion
    </script>

    <!-- Modo oscuro: leer preferencia guardada -->
    <script is:inline>
      const tema = localStorage.getItem('tema');
      if (tema === 'oscuro' || (!tema && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Barra de navegacion -->
    <BarraNavegacion idioma={idioma} paginaActual={pagina} />

    <!-- Contenido de la pagina -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Pie de pagina -->
    <PieDePagina idioma={idioma} />

    <!-- Boton flotante de WhatsApp -->
    <BotonWhatsapp />

    <!-- SEO: Datos de la empresa para Google -->
    <DatosEmpresa />
  </body>
</html>
