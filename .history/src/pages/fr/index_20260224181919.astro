---
import Principal from '../../layout/Principal.astro';
import BannerPrincipal from '../../componentes/inicio/BannerPrincipal.astro';
import NuestrosClientes from '../../componentes/inicio/NuestrosClientes.astro';
import ResumenServicios from '../../componentes/inicio/ResumenServicios.astro';
import PorQueElegirnos from '../../componentes/inicio/PorQueElegirnos.astro';
import BannerCotizar from '../../componentes/inicio/BannerCotizar.astro';
import MapaIdiomas from '../../componentes/inicio/MapaIdiomas.jsx';
import { obtenerTextos } from '../../helpers/idiomas';
const t = obtenerTextos('fr');
---
<Principal titulo={t.seo.inicio.titulo} descripcion={t.seo.inicio.descripcion} idioma="fr" pagina="inicio">
  <BannerPrincipal idioma="fr" />
  <NuestrosClientes idioma="fr" />
  <ResumenServicios idioma="fr" />
  <PorQueElegirnos idioma="fr" />

  <!-- Section Carte de Couverture Mondiale -->
  <section class="py-20 md:py-28 relative overflow-hidden" style="background: linear-gradient(180deg, #050a14 0%, #0a1220 50%, #050a14 100%);">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase mb-4"
          style="background: rgba(59,130,246,0.1); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2);">
          Couverture Internationale
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-5" style="font-family: 'Sora', sans-serif; line-height: 1.15;">
          Portée Mondiale
        </h2>
        <p class="text-base sm:text-lg max-w-2xl mx-auto" style="color: #7a8fa8; line-height: 1.7;">
          Nous connectons les cultures grâce à des traductions précises dans les langues qui font bouger le monde.
          De Lima, Pérou, vers tous les continents.
        </p>
      </div>
      <MapaIdiomas client:visible />
    </div>
  </section>

  <BannerCotizar idioma="fr" />
</Principal>