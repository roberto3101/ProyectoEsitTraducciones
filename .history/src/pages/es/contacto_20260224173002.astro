---
import Principal from '../../layout/Principal.astro';
import Formulario from '../../componentes/contacto/Formulario.astro';
import InfoContacto from '../../componentes/contacto/InfoContacto.astro';
import RedesSociales from '../../componentes/contacto/RedesSociales.astro';
import { obtenerTextos } from '../../helpers/idiomas';
const t = obtenerTextos('es');
---
<Principal titulo={t.seo.contacto.titulo} descripcion={t.seo.contacto.descripcion} idioma="es" pagina="contacto">
  <section class="seccion">
    <div class="contenedor px-4">
      <div class="text-center">
        <h1 class="titulo-seccion">{t.contactoPage.titulo}</h1>
        <p class="subtitulo-seccion mx-auto">{t.contactoPage.subtitulo}</p>
      </div>
      <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <Formulario idioma="es" />
        </div>
        <div>
          <InfoContacto idioma="es" />
          <RedesSociales />
        </div>
      </div>
    </div>
  </section>
</Principal>
