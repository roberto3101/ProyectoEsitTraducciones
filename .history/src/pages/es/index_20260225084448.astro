---
import Principal from '../../layout/Principal.astro';
import BannerPrincipal from '../../componentes/inicio/BannerPrincipal.astro';
import NuestrosClientes from '../../componentes/inicio/NuestrosClientes.astro';
import ResumenServicios from '../../componentes/inicio/ResumenServicios.astro';
import PorQueElegirnos from '../../componentes/inicio/PorQueElegirnos.astro';
import Testimonios from '../../componentes/inicio/Testimonios.astro';
import BannerCotizar from '../../componentes/inicio/BannerCotizar.astro';
import MapaIdiomas from '../../componentes/inicio/MapaIdiomas.jsx';
import { obtenerTextos } from '../../helpers/idiomas';
const t = obtenerTextos('es');
---
<Principal titulo={t.seo.inicio.titulo} descripcion={t.seo.inicio.descripcion} idioma="es" pagina="inicio">
  <BannerPrincipal idioma="es" />
  <NuestrosClientes idioma="es" />
  <ResumenServicios idioma="es" />
  <PorQueElegirnos idioma="es" />

  <!-- Mapa de Alcance Global -->
  <section class="py-20 md:py-28 relative overflow-hidden bg-gray-50 dark:bg-transparent">
    <div class="absolute inset-0 hidden dark:block" style="background: linear-gradient(180deg, #050a14 0%, #0a1220 50%, #050a14 100%);"></div>
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 relative z-10">
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase mb-4
          bg-marca-azul/5 text-marca-azul border border-marca-azul/10
          dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20">
          Cobertura Internacional
        </span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-marca-azul dark:text-white mb-5" style="font-family: 'Sora', sans-serif; line-height: 1.15;">
          Alcance Global
        </h2>
        <p class="text-base sm:text-lg max-w-2xl mx-auto text-marca-gris dark:text-slate-400" style="line-height: 1.7;">
          Conectamos culturas a través de traducciones precisas en los idiomas que mueven al mundo. Desde Lima, Perú, hacia todos los continentes.
        </p>
      </div>
      <MapaIdiomas client:visible />
    </div>
  </section>

  <Testimonios idioma="es" />
  <BannerCotizar idioma="es" />
</Principal>