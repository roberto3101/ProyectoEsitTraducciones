---
import Principal from '../../layout/Principal.astro';
import BannerPrincipal from '../../componentes/inicio/BannerPrincipal.astro';
import NuestrosClientes from '../../componentes/inicio/NuestrosClientes.astro';
import ResumenServicios from '../../componentes/inicio/ResumenServicios.astro';
import PorQueElegirnos from '../../componentes/inicio/PorQueElegirnos.astro';
import BannerCotizar from '../../componentes/inicio/BannerCotizar.astro';
import { obtenerTextos } from '../../helpers/idiomas';
const t = obtenerTextos('en');
---
<Principal titulo={t.seo.inicio.titulo} descripcion={t.seo.inicio.descripcion} idioma="en" pagina="inicio">
  <BannerPrincipal idioma="en" />
  <NuestrosClientes idioma="en" />
  <ResumenServicios idioma="en" />
  <PorQueElegirnos idioma="en" />
  <BannerCotizar idioma="en" />
</Principal>
