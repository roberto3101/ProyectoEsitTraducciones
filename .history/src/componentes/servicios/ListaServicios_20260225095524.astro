---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';

interface Props { idioma: Idioma; }

const { idioma } = Astro.props;
const t = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);

// ── 5 servicios reales de ESIT (investigados desde esittraducciones.com) ──
const servicios = [
  {
    id: "traduccion",
