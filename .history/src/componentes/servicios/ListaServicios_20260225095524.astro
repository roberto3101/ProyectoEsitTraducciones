    color: "#059669",
    colorLight: "#D1FAE5",
    colorDark: "#134E3A",
  },
  {
    id: "subtitulado",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h1.5C5.496 19.5 6 18.996 6 18.375m-3.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-1.5A1.125 1.125 0 0118 18.375M20.625 4.5H3.375m17.25 0c.621 0 1.125.504 1.125 1.125M20.625 4.5h-1.5C18.504 4.5 18 5.004 18 5.625m3.75 0v1.5c0 .621-.504 1.125-1.125 1.125M3.375 4.5c-.621 0-1.125.504-1.125 1.125M3.375 4.5h1.5C5.496 4.5 6 5.004 6 5.625m-3.75 0v1.5c0 .621.504 1.125 1.125 1.125m0 0h1.5m-1.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m1.5-3.75C5.496 8.25 6 7.746 6 7.125v-1.5" />
    </svg>`,
    titulo: { es: "Subtitulado y Doblaje", en: "Subtitling & Dubbing", fr: "Sous-titrage et Doublage" },
    subtitulo: {
      es: "Contenido audiovisual accesible en cualquier idioma",
      en: "Audiovisual content accessible in any language",
      fr: "Contenu audiovisuel accessible dans toutes les langues"
    },
    descripcion: {
      es: "Subtitulado profesional, doblaje y locución (voice-over) para videos corporativos, material de capacitación, documentales, contenido educativo y campañas institucionales. Utilizamos software especializado para garantizar sincronización perfecta y calidad broadcast. Ofrecemos subtítulos abiertos, cerrados (CC), y subtitulado para personas con discapacidad auditiva.",
      en: "Professional subtitling, dubbing, and voice-over for corporate videos, training material, documentaries, educational content, and institutional campaigns. We use specialized software to ensure perfect synchronization and broadcast quality. We offer open subtitles, closed captions (CC), and subtitling for the hearing impaired.",
      fr: "Sous-titrage professionnel, doublage et voix off pour vidéos corporatives, matériel de formation, documentaires, contenu éducatif et campagnes institutionnelles. Nous utilisons des logiciels spécialisés pour garantir une synchronisation parfaite et une qualité broadcast. Nous offrons des sous-titres ouverts, fermés (CC) et pour les malentendants."
    },
    especialidades: {
      es: ["Subtitulado", "Doblaje", "Voice-over", "Closed Captions", "E-learning", "Videos Corporativos"],
      en: ["Subtitling", "Dubbing", "Voice-over", "Closed Captions", "E-learning", "Corporate Videos"],
      fr: ["Sous-titrage", "Doublage", "Voix off", "Closed Captions", "E-learning", "Vidéos Corporatives"]
    },
    sectores: {
      es: ["Educación", "ONG", "Medios", "Corporativo", "Gobierno"],
      en: ["Education", "NGOs", "Media", "Corporate", "Government"],
      fr: ["Éducation", "ONG", "Médias", "Corporatif", "Gouvernement"]
    },
    color: "#7C3AED",
    colorLight: "#EDE9FE",
    colorDark: "#3B1F70",
  },
  {
    id: "textos",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
    </svg>`,
    titulo: { es: "Servicios para Textos", en: "Text Services", fr: "Services pour Textes" },
    subtitulo: {
      es: "Edición, corrección y adaptación cultural de contenidos",
      en: "Editing, proofreading, and cultural adaptation of content",
      fr: "Édition, correction et adaptation culturelle de contenus"
    },
    descripcion: {
      es: "Edición y corrección de estilo en español, inglés y francés. Transcripción de audio y video. Redacción y adaptación cultural de textos para mercados específicos. Localización de contenido web, aplicaciones y material de marketing. Revisión de traducciones existentes para asegurar calidad y coherencia terminológica.",
      en: "Editing and proofreading in Spanish, English, and French. Audio and video transcription. Copywriting and cultural adaptation of texts for specific markets. Localization of web content, applications, and marketing material. Review of existing translations to ensure quality and terminological consistency.",
      fr: "Édition et correction de style en espagnol, anglais et français. Transcription audio et vidéo. Rédaction et adaptation culturelle de textes pour des marchés spécifiques. Localisation de contenu web, applications et matériel marketing. Révision de traductions existantes pour assurer qualité et cohérence terminologique."
    },
    especialidades: {
      es: ["Edición", "Corrección de Estilo", "Transcripción", "Localización", "Redacción", "Revisión"],
      en: ["Editing", "Proofreading", "Transcription", "Localization", "Copywriting", "Review"],
      fr: ["Édition", "Correction", "Transcription", "Localisation", "Rédaction", "Révision"]
    },
    sectores: {
      es: ["Marketing", "Editorial", "Tecnología", "Investigación", "Comunicación"],
      en: ["Marketing", "Publishing", "Technology", "Research", "Communications"],
