    color: "#2563EB",
    colorLight: "#DBEAFE",
    colorDark: "#1E3A5F",
  },
  {
    id: "interpretacion",
    icono: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
    </svg>`,
    titulo: { es: "Interpretación Profesional", en: "Professional Interpretation", fr: "Interprétation Professionnelle" },
    subtitulo: {
      es: "Comunicación en tiempo real para eventos de alto nivel",
      en: "Real-time communication for high-level events",
      fr: "Communication en temps réel pour événements de haut niveau"
