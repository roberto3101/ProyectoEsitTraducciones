const txt: Record<string, Record<string, string>> = {
  badge: { es: "Nuestros Servicios", en: "Our Services", fr: "Nos Services" },
  titulo: { es: "Servicios Profesionales", en: "Professional Services", fr: "Services Professionnels" },
  subtitulo: {
    es: "Más de 33 años ofreciendo soluciones lingüísticas integrales a organismos internacionales, gobiernos y empresas líderes.",
    en: "Over 33 years offering comprehensive linguistic solutions to international organizations, governments, and leading companies.",
    fr: "Plus de 33 ans à offrir des solutions linguistiques complètes aux organisations internationales, gouvernements et entreprises leaders."
  },
  especialidades: { es: "Especialidades", en: "Specialties", fr: "Spécialités" },
  sectores: { es: "Sectores", en: "Sectors", fr: "Secteurs" },
  cotizar: { es: "Solicitar cotización", en: "Request a quote", fr: "Demander un devis" },
  ctaTitulo: { es: "¿Listo para empezar?", en: "Ready to get started?", fr: "Prêt à commencer ?" },
  ctaDesc: {
    es: "Cuéntenos sobre su proyecto y reciba una cotización personalizada en menos de 24 horas.",
    en: "Tell us about your project and receive a personalized quote within 24 hours.",
    fr: "Parlez-nous de votre projet et recevez un devis personnalisé en moins de 24 heures."
  },
  ctaBoton: { es: "Contáctenos ahora", en: "Contact us now", fr: "Contactez-nous maintenant" },
  ctaWhatsapp: { es: "Escribir por WhatsApp", en: "Message on WhatsApp", fr: "Écrire sur WhatsApp" },
};
---

<section class="py-20 md:py-28 relative overflow-hidden bg-white dark:bg-oscuro-fondo">
  <!-- Decoración -->
  <div class="absolute top-40 -right-32 w-[500px] h-[500px] rounded-full opacity-[0.025] dark:opacity-[0.015]"
    style="background: radial-gradient(circle, #2563EB, transparent); filter: blur(100px);"></div>
  <div class="absolute bottom-40 -left-32 w-[500px] h-[500px] rounded-full opacity-[0.02] dark:opacity-[0.015]"
    style="background: radial-gradient(circle, #059669, transparent); filter: blur(100px);"></div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">

    <!-- Encabezado -->
    <div class="text-center mb-16 md:mb-20">
      <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase mb-5
        bg-marca-azul/5 text-marca-azul border border-marca-azul/10
        dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20">
        {txt.badge[idioma]}
      </span>
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-marca-azul dark:text-white mb-5"
        style="font-family: 'Sora', sans-serif; line-height: 1.15;">
        {txt.titulo[idioma]}
      </h1>
      <p class="text-base sm:text-lg text-marca-gris dark:text-slate-400 max-w-2xl mx-auto" style="line-height: 1.7;">
        {txt.subtitulo[idioma]}
      </p>
    </div>

    <!-- Lista de servicios -->
    <div class="space-y-8">
      {servicios.map((srv, i) => (
        <div id={srv.id}
          class="group relative rounded-2xl overflow-hidden transition-all duration-500 hover:shadow-xl
            bg-white dark:bg-oscuro-tarjeta
            border border-slate-100 dark:border-oscuro-borde
            hover:shadow-black/[0.04] dark:hover:shadow-black/30"
        >
          {/* Línea lateral de color */}
          <div class="absolute left-0 top-0 bottom-0 w-1 transition-all duration-500 group-hover:w-1.5"
            style={`background: ${srv.color};`}></div>

          <div class="p-7 sm:p-8 lg:p-10 pl-8 sm:pl-10 lg:pl-12">
            {/* Header: icono + título + subtítulo */}
            <div class="flex flex-col sm:flex-row sm:items-start gap-5 mb-6">
              <div class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center transition-all duration-300
                group-hover:scale-110 group-hover:shadow-lg"
                style={`background: ${srv.color}10; color: ${srv.color}; --tw-shadow-color: ${srv.color}20;`}>
                <Fragment set:html={srv.icono} />
              </div>
              <div class="flex-1">
                <h2 class="text-xl sm:text-2xl font-bold text-marca-azul dark:text-white mb-1.5"
                  style="font-family: 'Sora', sans-serif;">
                  {srv.titulo[idioma]}
                </h2>
                <p class="text-sm font-medium" style={`color: ${srv.color};`}>
                  {srv.subtitulo[idioma]}
                </p>
              </div>
            </div>

            {/* Descripción */}
            <p class="text-sm sm:text-[15px] text-marca-gris dark:text-slate-400 leading-relaxed mb-7"
              style="line-height: 1.75;">
              {srv.descripcion[idioma]}
            </p>

            {/* Grid: Especialidades + Sectores */}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-7">
              {/* Especialidades */}
              <div>
                <h4 class="text-[11px] font-bold uppercase tracking-wider mb-3
                  text-slate-400 dark:text-slate-500">
                  {txt.especialidades[idioma]}
                </h4>
                <div class="flex flex-wrap gap-2">
                  {srv.especialidades[idioma].map((esp: string) => (
                    <span class="px-3 py-1.5 text-xs font-semibold rounded-lg transition-colors
                      bg-slate-50 text-slate-600 border border-slate-100
                      dark:bg-white/[0.04] dark:text-slate-300 dark:border-white/[0.08]
                      group-hover:border-opacity-60"
                      style={`--hover-bg: ${srv.color}08;`}>
                      {esp}
                    </span>
                  ))}
                </div>
              </div>

              {/* Sectores */}
              <div>
                <h4 class="text-[11px] font-bold uppercase tracking-wider mb-3
                  text-slate-400 dark:text-slate-500">
                  {txt.sectores[idioma]}
                </h4>
                <div class="flex flex-wrap gap-2">
                  {srv.sectores[idioma].map((sec: string) => (
                    <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg
                      bg-slate-50 text-slate-500 border border-slate-100
                      dark:bg-white/[0.03] dark:text-slate-400 dark:border-white/[0.06]">
                      <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${srv.color}60;`}></span>
                      {sec}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            {/* CTA */}
            <div class="flex flex-wrap gap-3 pt-5 border-t border-slate-100 dark:border-oscuro-borde">
              <a href={rutas.contacto}
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold text-white
                  transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg"
                style={`background: ${srv.color}; --tw-shadow-color: ${srv.color}30;`}>
                {txt.cotizar[idioma]}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a href="https://wa.me/51998152086" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold
                  bg-green-50 text-green-700 border border-green-200
                  hover:bg-green-100
                  dark:bg-green-500/10 dark:text-green-400 dark:border-green-500/20
                  dark:hover:bg-green-500/20
                  transition-all duration-300">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
