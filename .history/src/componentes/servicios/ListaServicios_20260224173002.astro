---
import TarjetaServicio from './TarjetaServicio.astro';
import { obtenerTextos, type Idioma } from '../../helpers/idiomas';
interface Props { idioma: Idioma; }
const { idioma } = Astro.props;
const t = obtenerTextos(idioma);
---
<section class="seccion">
  <div class="contenedor px-4">
    <div class="text-center">
      <h1 class="titulo-seccion">{t.resumenServicios.titulo}</h1>
      <p class="subtitulo-seccion mx-auto">{t.resumenServicios.subtitulo}</p>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      {t.resumenServicios.items.map((item) => (
        <TarjetaServicio titulo={item.titulo} descripcion={item.descripcion} />
      ))}
    </div>
  </div>
</section>
