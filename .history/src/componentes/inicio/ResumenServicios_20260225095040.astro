---

<section class="py-20 md:py-28 relative overflow-hidden bg-white dark:bg-oscuro-fondo" id="servicios">
  <!-- Decoración sutil de fondo -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full opacity-[0.02] dark:opacity-[0.015]"
    style="background: radial-gradient(circle, #2563EB, transparent); filter: blur(100px);"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 relative z-10">

    <!-- Encabezado -->
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase mb-5
        bg-marca-azul/5 text-marca-azul border border-marca-azul/10
        dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20">
        {txt.badge}
      </span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-marca-azul dark:text-white mb-5"
        style="font-family: 'Sora', sans-serif; line-height: 1.15;">
        {txt.titulo}
      </h2>
      <p class="text-base sm:text-lg text-marca-gris dark:text-slate-400 max-w-2xl mx-auto" style="line-height: 1.7;">
        {txt.subtitulo}
      </p>
    </div>

    <!-- Grid de servicios: 2 arriba + 3 abajo -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6 mb-5 lg:mb-6">
      {servicios.slice(0, 2).map((srv, i) => (
        <div class={`group relative rounded-2xl p-7 lg:p-8 transition-all duration-500 hover:-translate-y-1
          bg-gradient-to-br ${srv.accent}
          border border-slate-100 dark:border-oscuro-borde ${srv.borderAccent}
          hover:shadow-xl hover:shadow-black/[0.03] dark:hover:shadow-black/20`}
        >
          {/* Icono */}
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-all duration-300"
            style={`background: ${srv.color}12; color: ${srv.color};`}>
            <Fragment set:html={srv.icono} />
          </div>

          {/* Título */}
          <h3 class="text-xl font-bold text-marca-azul dark:text-white mb-3"
            style="font-family: 'Sora', sans-serif;">
            {srv.titulo[idioma]}
          </h3>

          {/* Descripción */}
          <p class="text-sm text-marca-gris dark:text-slate-400 leading-relaxed mb-5">
            {srv.descripcion[idioma]}
          </p>

          {/* Tags */}
          <div class="flex flex-wrap gap-2 mb-6">
            {srv.tags[idioma].map((tag: string) => (
              <span class="px-2.5 py-1 text-[11px] font-semibold rounded-md
                bg-white/80 text-slate-500 border border-slate-100
                dark:bg-white/5 dark:text-slate-400 dark:border-white/10"
                style="letter-spacing: 0.02em;">
                {tag}
              </span>
            ))}
          </div>

          {/* CTA */}
          <a href={rutas.contacto}
            class="inline-flex items-center gap-2 text-sm font-semibold transition-all duration-300
              group-hover:gap-3"
            style={`color: ${srv.color};`}>
            {txt.cotizar}
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          {/* Línea decorativa inferior */}
          <div class="absolute bottom-0 left-7 right-7 h-0.5 rounded-full transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"
            style={`background: ${srv.color}40;`}></div>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:gap-6">
      {servicios.slice(2).map((srv, i) => (
        <div class={`group relative rounded-2xl p-7 lg:p-8 transition-all duration-500 hover:-translate-y-1
          bg-gradient-to-br ${srv.accent}
          border border-slate-100 dark:border-oscuro-borde ${srv.borderAccent}
          hover:shadow-xl hover:shadow-black/[0.03] dark:hover:shadow-black/20`}
        >
          {/* Icono */}
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-all duration-300"
            style={`background: ${srv.color}12; color: ${srv.color};`}>
            <Fragment set:html={srv.icono} />
          </div>

          {/* Título */}
          <h3 class="text-lg font-bold text-marca-azul dark:text-white mb-3"
            style="font-family: 'Sora', sans-serif;">
            {srv.titulo[idioma]}
          </h3>

          {/* Descripción */}
          <p class="text-sm text-marca-gris dark:text-slate-400 leading-relaxed mb-5">
            {srv.descripcion[idioma]}
          </p>

          {/* Tags */}
          <div class="flex flex-wrap gap-1.5 mb-5">
            {srv.tags[idioma].slice(0, 4).map((tag: string) => (
              <span class="px-2 py-0.5 text-[10px] font-semibold rounded-md
                bg-white/80 text-slate-500 border border-slate-100
                dark:bg-white/5 dark:text-slate-400 dark:border-white/10">
                {tag}
              </span>
            ))}
          </div>

          {/* CTA */}
          <a href={rutas.contacto}
            class="inline-flex items-center gap-2 text-sm font-semibold transition-all duration-300
              group-hover:gap-3"
            style={`color: ${srv.color};`}>
            {txt.cotizar}
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>

          {/* Línea decorativa inferior */}
          <div class="absolute bottom-0 left-7 right-7 h-0.5 rounded-full transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"
            style={`background: ${srv.color}40;`}></div>
        </div>
      ))}
    </div>

    <!-- Barra inferior: idiomas + CTA general -->
    <div class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-6 p-6 lg:p-8 rounded-2xl
      bg-slate-50 dark:bg-oscuro-tarjeta border border-slate-100 dark:border-oscuro-borde">
      
      <div class="flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center
          bg-marca-azulBrillante/10 dark:bg-marca-azulBrillante/15">
          <svg class="w-5 h-5 text-marca-azulBrillante" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3m3.334 2.364C11.176 10.658 7.69 15.08 3 17.502m9.334-12.138c.896.061 1.785.147 2.666.257m-4.589 8.495a18.023 18.023 0 01-3.827-5.802" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">
            {txt.idiomas}
          </p>
          <p class="text-sm font-bold text-marca-azul dark:text-white" style="font-family: 'Sora', sans-serif;">
            {txt.idiomasTexto}
          </p>
        </div>
      </div>

      <div class="flex gap-3 flex-wrap justify-center">
        <a href={rutas.servicios}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold
            bg-marca-azul hover:bg-marca-azulClaro text-white
            shadow-lg shadow-marca-azul/15 hover:shadow-marca-azul/25
            transition-all duration-300 hover:-translate-y-0.5"
          style="font-family: 'Sora', sans-serif;">
          {txt.verTodos}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={rutas.contacto}
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold
            border-2 border-marca-azul/20 text-marca-azul
            hover:bg-marca-azul hover:text-white
            dark:border-blue-400/20 dark:text-blue-400
            dark:hover:bg-blue-500 dark:hover:text-white dark:hover:border-blue-500
            transition-all duration-300"
          style="font-family: 'Sora', sans-serif;">
          {txt.cotizar}
        </a>
      </div>
    </div>
  </div>
</section>