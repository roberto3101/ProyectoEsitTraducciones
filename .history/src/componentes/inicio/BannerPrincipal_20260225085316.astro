---
import { obtenerTextos, obtenerRutas, type Idioma } from '../../helpers/idiomas';

interface Props { idioma: Idioma; }

const { idioma } = Astro.props as { idioma: 'es' | 'en' | 'fr' };
const t = obtenerTextos(idioma);
const rutas = obtenerRutas(idioma);

const stats: Record<string, { valor: string; label: string }[]> = {
  es: [
    { valor: "33+", label: "Años de experiencia" },
    { valor: "3", label: "Idiomas profesionales" },
    { valor: "500+", label: "Proyectos completados" },
    { valor: "100%", label: "Confidencialidad" },
  ],
  en: [
    { valor: "33+", label: "Years of experience" },
    { valor: "3", label: "Professional languages" },
    { valor: "500+", label: "Projects completed" },
    { valor: "100%", label: "Confidentiality" },
  ],
  fr: [
    { valor: "33+", label: "Ans d'expérience" },
    { valor: "3", label: "Langues professionnelles" },
    { valor: "500+", label: "Projets réalisés" },
    { valor: "100%", label: "Confidentialité" },
  ],
};

const badgeText: Record<string, string> = {
  es: "Agencia de traducción profesional desde 1992",
  en: "Professional translation agency since 1992",
  fr: "Agence de traduction professionnelle depuis 1992",
};
---

<section id="hero-section" class="relative overflow-hidden min-h-[600px] md:min-h-[700px] flex flex-col
  bg-gradient-to-br from-white via-slate-50 to-blue-50/50
  dark:bg-none dark:bg-oscuro-fondo">

  {/* Dark mode base */}
  <div class="absolute inset-0 hidden dark:block"
    style="background: linear-gradient(135deg, #060c18 0%, #0a1525 40%, #0d1a30 70%, #060c18 100%);">
  </div>

  {/* Canvas for animation */}
  <canvas id="hero-canvas" class="absolute inset-0 z-[1]" style="width:100%;height:100%;"></canvas>

  {/* Text readability — left side only */}
  <div class="absolute inset-0 z-[2] pointer-events-none dark:hidden"
    style="background: linear-gradient(to right, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0.25) 40%, transparent 60%);">
  </div>
  <div class="absolute inset-0 z-[2] pointer-events-none hidden dark:block"
    style="background: linear-gradient(to right, rgba(6,12,24,0.65) 0%, rgba(6,12,24,0.25) 40%, transparent 60%);">
  </div>

  {/* Bottom fade */}
  <div class="absolute bottom-0 left-0 right-0 h-20 z-[2] pointer-events-none
    bg-gradient-to-t from-white to-transparent
    dark:from-oscuro-fondo dark:to-transparent">
  </div>

  {/* Content */}
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 relative z-[3] flex-1 flex items-center py-24 md:py-32 lg:py-40">
    <div class="max-w-2xl">
      <div class="hero-fade-in" style="animation-delay: 0.1s;">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-semibold tracking-wider uppercase
          bg-marca-azul/8 text-marca-azul border border-marca-azul/15 backdrop-blur-sm
          dark:bg-blue-500/10 dark:text-blue-400 dark:border-blue-500/20">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
          {badgeText[idioma]}
        </span>
      </div>

      <h1 class="mt-7 hero-fade-in text-marca-azul dark:text-white"
        style="font-family: 'Sora', sans-serif; font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 800; line-height: 1.1; letter-spacing: -0.02em; animation-delay: 0.25s;">
        {t.hero.titulo}
      </h1>

      <p class="mt-6 hero-fade-in text-marca-gris dark:text-slate-400"
        style="font-size: clamp(1rem, 2vw, 1.2rem); line-height: 1.7; max-width: 540px; animation-delay: 0.4s;">
        {t.hero.subtitulo}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row gap-4 hero-fade-in" style="animation-delay: 0.55s;">
        <a href={`/${idioma}/${rutas.contacto}`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl
            bg-marca-azul hover:bg-marca-azulClaro text-white
            font-semibold text-base shadow-xl shadow-marca-azul/20 hover:shadow-marca-azul/30
            transition-all duration-300 hover:-translate-y-0.5 active:translate-y-0"
          style="font-family: 'Sora', sans-serif;">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {t.hero.botonContacto}
        </a>
        <a href={`/${idioma}/${rutas.servicios}`}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-xl
            border-2 font-semibold text-base transition-all duration-300
            border-marca-azul/20 text-marca-azul hover:bg-marca-azul/5 backdrop-blur-sm
            dark:border-white/15 dark:text-white dark:hover:bg-white/5"
          style="font-family: 'Sora', sans-serif;">
          {t.hero.botonServicios}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>

  {/* Stats bar */}
  <div class="relative z-[3] border-t
    border-slate-200/50 bg-white/70 backdrop-blur-md
    dark:border-white/5 dark:bg-black/30 dark:backdrop-blur-md">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-0">
        {stats[idioma].map((s, i) => (
          <div class:list={[
            "py-6 md:py-7 text-center hero-fade-in",
            i < 3 ? "border-r border-slate-200/50 dark:border-white/5" : "",
            i < 2 ? "max-md:border-b max-md:border-slate-200/50 max-md:dark:border-white/5" : "",
            i === 2 ? "max-md:border-b max-md:border-slate-200/50 max-md:dark:border-white/5 max-md:border-r-0" : "",
            i === 1 ? "max-md:border-r-0" : "",
            i === 3 ? "max-md:border-r-0" : "",
          ]} style={`animation-delay: ${0.6 + i * 0.1}s;`}>
            <div class="text-2xl md:text-3xl font-bold text-marca-azulBrillante dark:text-blue-400"
              style="font-family: 'Sora', sans-serif;">
              {s.valor}
            </div>
            <div class="mt-1 text-xs md:text-sm text-marca-gris dark:text-slate-500">
              {s.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-fade-in {
    opacity: 0;
    animation: heroFadeIn 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
</style>

<script is:inline>
(function() {
  const canvas = document.getElementById('hero-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const section = document.getElementById('hero-section');
  let w, h, particles = [], mouseX = -1000, mouseY = -1000, animId;

  function isDark() {
    return document.documentElement.classList.contains('dark');
  }

  function resize() {
    const rect = section.getBoundingClientRect();
    w = rect.width;
    h = rect.height;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    initParticles();
  }

  function initParticles() {
    const count = Math.min(85, Math.floor((w * h) / 10000));
    particles = [];
    for (let i = 0; i < count; i++) {
      particles.push({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.5,
        vy: (Math.random() - 0.5) * 0.35,
        r: Math.random() * 2.2 + 1,
        hub: Math.random() < 0.18,
        pulse: Math.random() * Math.PI * 2
      });
    }
  }

  function draw() {
    const dark = isDark();
    ctx.clearRect(0, 0, w, h);

    const maxDist = Math.min(180, w * 0.15);

    // Update
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      p.pulse += 0.018;

      // Mouse repulsion
      const mdx = p.x - mouseX;
      const mdy = p.y - mouseY;
      const mDist = Math.sqrt(mdx * mdx + mdy * mdy);
      if (mDist < 200 && mDist > 0) {
        const force = (1 - mDist / 200) * 1.2;
        p.vx += (mdx / mDist) * force;
        p.vy += (mdy / mDist) * force;
      }

      p.vx *= 0.985;
      p.vy *= 0.985;
      p.x += p.vx;
      p.y += p.vy;

      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;
      if (p.y < -10) p.y = h + 10;
      if (p.y > h + 10) p.y = -10;
    }

    // Connections
    for (let i = 0; i < particles.length; i++) {
      for (let j = i + 1; j < particles.length; j++) {
        const a = particles[i], b = particles[j];
        const dx = a.x - b.x, dy = a.y - b.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < maxDist) {
          const s = 1 - dist / maxDist;
          const alpha = dark ? s * 0.4 : s * 0.18;
          ctx.strokeStyle = dark
            ? 'rgba(100,180,255,' + alpha + ')'
            : 'rgba(37,99,235,' + alpha + ')';
          ctx.lineWidth = (a.hub || b.hub) ? s * 1.8 : s * 0.8;
          ctx.beginPath();
          ctx.moveTo(a.x, a.y);
          ctx.lineTo(b.x, b.y);
          ctx.stroke();
        }
      }
    }

    // Particles
    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];
      const ps = 1 + Math.sin(p.pulse) * 0.3;

      // Hub glow
      if (p.hub) {
        const gr = p.r * 10 * ps;
        const glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, gr);
        glow.addColorStop(0, dark ? 'rgba(96,165,250,0.18)' : 'rgba(37,99,235,0.1)');
        glow.addColorStop(1, dark ? 'rgba(96,165,250,0)' : 'rgba(37,99,235,0)');
        ctx.fillStyle = glow;
        ctx.beginPath();
        ctx.arc(p.x, p.y, gr, 0, Math.PI * 2);
        ctx.fill();
      }

      // Dot
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r * (p.hub ? ps : 1), 0, Math.PI * 2);
      if (dark) {
        ctx.fillStyle = p.hub ? 'rgba(147,197,253,0.85)' : 'rgba(147,197,253,0.5)';
      } else {
        ctx.fillStyle = p.hub ? 'rgba(37,99,235,0.45)' : 'rgba(37,99,235,0.22)';
      }
      ctx.fill();

      // Hub core
      if (p.hub) {
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r * 0.4, 0, Math.PI * 2);
        ctx.fillStyle = dark ? 'rgba(220,235,255,0.7)' : 'rgba(37,99,235,0.45)';
        ctx.fill();
      }
    }

    // Ambient glow right side
    const cx = w * 0.7, cy = h * 0.4, gr = Math.min(w, h) * 0.45;
    const ag = ctx.createRadialGradient(cx, cy, 0, cx, cy, gr);
    ag.addColorStop(0, dark ? 'rgba(37,99,235,0.07)' : 'rgba(37,99,235,0.04)');
    ag.addColorStop(0.5, dark ? 'rgba(37,99,235,0.025)' : 'rgba(37,99,235,0.015)');
    ag.addColorStop(1, 'rgba(37,99,235,0)');
    ctx.fillStyle = ag;
    ctx.fillRect(0, 0, w, h);

    animId = requestAnimationFrame(draw);
  }

  canvas.addEventListener('mousemove', function(e) {
    const rect = canvas.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
  });
  canvas.addEventListener('mouseleave', function() {
    mouseX = -1000;
    mouseY = -1000;
  });

  window.addEventListener('resize', resize);
  resize();
  animId = requestAnimationFrame(draw);
})();
</script>